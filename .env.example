# Groq (console.groq.com/keys)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Twilio (console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vercel KV — preenchido automaticamente ao ligar o KV no dashboard do Vercel
KV_REST_API_URL=https://xxxxxxxx.upstash.io
KV_REST_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx

# Opcional: limitar a quem pode usar o bot (o teu número WhatsApp)
# Formato: whatsapp:+351912345678
ALLOWED_NUMBER=whatsapp:+351912345678
